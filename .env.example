# Exemplo de configuração do KDD. NÃO comite o ~/.env real (é PÚBLICO o repo).
# As três soluções (API/deploy, desktop, bot) leem estas chaves do ambiente
# ou de ~/.env. Copie para ~/.env e preencha com os valores reais.

# --- Web API / deploy (Hostinger) ---
KDD_APP_URL=https://SEU-SITE.hostingersite.com
KDD_DB_NAME=u000000000_kdd
KDD_DB_USER=u000000000_kdd
KDD_DB_PASS=senha-do-banco

# SSH (deploy via rsync)
KDD_SSH_HOST=000.0.0.0
KDD_SSH_PORT=65002
KDD_SSH_USER=u000000000
KDD_SSH_PASS=senha-ssh

# --- Tokens de acesso à API (perfis organizacionais) ---
KDD_TOKEN_OPERADOR=token-do-operador   # o bot usa este
KDD_TOKEN_VALIDADOR=token-do-validador # quem aprova/reprova

# --- Bot (Marco 3) ---
# Backend de IA: auto (=> ollama, local/sem custo; nunca escolhe pago sozinho)
#   | claude (API, pago) | cli (Claude Code, pago) | ollama (local)
# Pode também escolher na linha de comando: main.py --backend <...> [--max-fontes N]
KDD_IA_BACKEND=auto
# >>> A ÚNICA chave que falta para rodar o bot na nuvem: <<<
ANTHROPIC_API_KEY=sk-ant-...
KDD_CLAUDE_MODEL=claude-sonnet-4-6
# Ollama local (alternativa offline, lenta em CPU). Modelo dimensionado para a
# máquina-alvo (i5-6200U, ~11 GB RAM, sem GPU): qwen2.5:7b-instruct (~4.7 GB).
KDD_OLLAMA_URL=http://localhost:11434
KDD_OLLAMA_MODEL=qwen2.5:7b-instruct
KDD_MAX_CHARS_PDF=60000
