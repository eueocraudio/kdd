# === KDD Web API — modelo de configuração ===
# Copie para `.env` e preencha. NÃO coloque segredos reais aqui (este é versionado).

# --- Site / Hostinger ---
APP_ENV=producao
APP_URL=https://SEU-SITE.hostingersite.com

# --- Banco de dados MySQL (Hostinger) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nome_do_banco
DB_USER=usuario
DB_PASS=senha
DB_CHARSET=utf8mb4

# --- Armazenamento de PDFs (relativo à raiz da app = pasta api/) ---
PDF_STORAGE_PATH=storage/pdfs

# --- Arquivo de tokens liberados (relativo à raiz da app) ---
TOKENS_FILE=tokens.json
